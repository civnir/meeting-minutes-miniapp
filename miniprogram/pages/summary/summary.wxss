.container { padding: 32rpx; }
.card { background:#fff; border-radius: 16rpx; padding: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,.06); }
.title { display:block; font-size: 34rpx; font-weight: 600; }
.meta { display:block; margin-top: 10rpx; color: #667085; }
.topic { margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx solid #eaecf0; }
.topic-title { display:block; font-weight: 600; margin-bottom: 8rpx; }
.todo { display:block; color:#344054; margin-left: 10rpx; }
.primary { margin-top: 28rpx; background:#1677ff; color:#fff; border-radius: 12rpx; }
