.container { padding: 32rpx; }
.card { background: #fff; border-radius: 20rpx; padding: 28rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.title { font-size: 40rpx; font-weight: 600; }
.subtitle { margin-top: 12rpx; color: #667085; display: block; }
.field { margin-top: 24rpx; }
.label { display: block; margin-bottom: 8rpx; color: #344054; }
.input { border: 1rpx solid #d0d5dd; border-radius: 12rpx; padding: 16rpx; }
.primary { margin-top: 32rpx; background: #1677ff; color: #fff; border-radius: 12rpx; }
